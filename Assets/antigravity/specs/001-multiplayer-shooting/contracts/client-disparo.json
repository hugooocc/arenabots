{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Client Shooting Event",
  "type": "object",
  "properties": {
    "tipo": { "type": "string", "const": "disparo" },
    "jugadorId": { "type": "string" },
    "partidaId": { "type": "string" },
    "posicion": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      },
      "required": ["x", "y"]
    },
    "direccion": {
      "type": "object",
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      },
      "required": ["x", "y"]
    },
    "timestamp": { "type": "integer" }
  },
  "required": ["tipo", "jugadorId", "partidaId", "posicion", "direccion", "timestamp"]
}
